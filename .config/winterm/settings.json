  "actions": [
    {
      "name": "Theme Switch...",
      "icon": "🎨",
      "commands": [
        {
          "name": "ayu-dark",
          "icon": "🌑",
          "command": {
            "action": "wt",
            "commandline": "split-pane -H -s 0.1 wsl.exe -d Ubuntu -- /home/spenser/.local/bin/theme-switch ayu-dark ; move-focus previous"
          }
        },
        {
          "name": "ayu-light",
          "icon": "☀️",
          "command": {
            "action": "wt",
